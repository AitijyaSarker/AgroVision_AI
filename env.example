# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Server (optional — Next.js /api routes work without it)
NEXT_PUBLIC_AI_SERVER_URL=http://localhost:8000
AI_SERVER_URL=http://localhost:8000

# Google Gemini for AI chatbot (server-side only — get key at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key
# Optional override (default tries gemini-2.5-flash first)
# GEMINI_MODEL=gemini-2.5-flash


