# Copy to .env.local and fill in real values (never commit .env.local)

# MongoDB Atlas — required for Sign Up / Sign In
# Format: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/agrovision?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_connection_string

# Secret for login tokens (any long random string for local dev)
JWT_SECRET=your_random_jwt_secret_here

# Google Gemini — AI chatbot
GEMINI_API_KEY=your_gemini_api_key

# Optional
NEXT_PUBLIC_API_URL=
FRONTEND_URL=http://localhost:3000
